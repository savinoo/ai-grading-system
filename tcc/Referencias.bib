@article{silva_inteligencia_2025,
	title = {Inteligência artificial na educação básica: possibilidades e limites éticos},
	volume = {17},
	issn = {1989-4155, 1989-4155},
	shorttitle = {Inteligência artificial na educação básica},
	url = {https://ojs.cuadernoseducacion.com/ojs/index.php/ced/article/view/8081},
	doi = {10.55905/cuadv17n4-106},
	abstract = {Este estudo teve como objetivo analisar as possibilidades e os limites éticos do uso da Inteligência Artificial (IA) na educação básica, focando nas vantagens e desafios que sua implementação pode trazer. O problema central investigado foi como a IA pode ser utilizada de maneira justa nas escolas, considerando as questões éticas, como a privacidade dos dados e o viés algorítmico. A pesquisa seguiu uma abordagem qualitativa, por meio de uma revisão bibliográfica de artigos, dissertações e livros relevantes sobre o tema. Os resultados mostraram que a IA tem o potencial de personalizar o ensino, melhorando o desempenho dos alunos e atendendo às suas necessidades individuais. No entanto, os desafios éticos, como o risco de discriminação nos algoritmos e a necessidade de garantir a privacidade dos dados dos alunos, foram identificados como questões centrais. A análise também destacou a importância da formação continuada dos professores, para que possam usar essas tecnologias de maneira ética. As considerações finais sugeriram que a IA deve ser implementada com políticas públicas que garantam a equidade no acesso e a proteção dos direitos dos alunos. A pesquisa também indicou a necessidade de mais estudos sobre o impacto da IA a longo prazo no ensino e na relação professor-aluno.},
	number = {4},
	urlaccessdate = {28 abr. 2025},
	journal = {Cuadernos de Educación y Desarrollo},
	author = {Silva, Marcia Romão and Pratti, Aline Rodrigues De Amorim Eler and Rocha, Ana Claudia Cunha and Macedo, Camila De Souza and Vieira, Claudia Da Silva Lima and Neto, Esmeralda Paulo and Silva, Jane Kerline Da and Silva, Luiz Vieira Da and Melo, Maria Tereza De},
	month = apr,
	year = {2025},
	pages = {e8081},
}

@article{guimaraes_junior_etica_2025,
	title = {Ética e privacidade no uso de inteligência artificial na sala de aula: como preparar os educadores?},
	volume = {18},
	copyright = {https://creativecommons.org/licenses/by-nc/4.0},
	issn = {1988-7833, 1988-7833},
	shorttitle = {Ética e privacidade no uso de inteligência artificial na sala de aula},
	url = {https://ojs.revistacontribuciones.com/ojs/index.php/clcs/article/view/14350},
	doi = {10.55905/revconv.18n.1-050},
	abstract = {A crescente presença da Inteligência Artificial (IA) no setor educacional tem provocado transformações profundas nas práticas pedagógicas. No entanto, essa evolução tecnológica traz consigo desafios éticos e de privacidade que precisam ser amplamente discutidos para garantir que o uso da IA seja benéfico e respeite os direitos dos alunos. A formação contínua de educadores para o uso adequado da IA não deve se limitar ao domínio das tecnologias, mas também abranger questões críticas relativas à ética, à segurança dos dados e à promoção de um ambiente educacional inclusivo e seguro. O uso da IA nas escolas implica no processamento de dados pessoais dos estudantes, o que exige uma atenção especial à privacidade e à proteção contra discriminação algorítmica. Além disso, é necessário garantir que os educadores desenvolvam habilidades para aplicar essas tecnologias de maneira responsável, evitando a reprodução de preconceitos e garantindo que os alunos possam se beneficiar dos avanços da IA sem comprometer sua autonomia ou privacidade. Este artigo visa discutir os principais aspectos éticos e de privacidade relacionados ao uso da IA no ambiente escolar, explorando como os educadores podem ser formados para lidar com esses desafios. A análise também aborda a importância de políticas educacionais que protejam os dados dos alunos e promovam uma integração ética da IA nas práticas pedagógicas. O objetivo central é discutir como a formação docente pode ser adaptada para preparar os professores para integrar a IA de forma ética, respeitosa e inclusiva, garantindo a segurança dos dados e o uso responsável da tecnologia.},
	number = {1},
	urlaccessdate = {28 abr. 2025},
	journal = {CONTRIBUCIONES A LAS CIENCIAS SOCIALES},
	author = {Guimaraes Junior, José Carlos and Nascimento, Isidro José Bezerra Maciel Fortaleza Do and Costa, Hilke Carlayle De Medeiros and Ferreira, Patrícia Da Silva and Grigigorio, Erica Lamara Gomes Alves and Vieira, Fernando Bueno and Bezerra, José Ronaldo Da Silva},
	month = jan,
	year = {2025},
	pages = {e14350},
}

