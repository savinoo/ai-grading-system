# LLM Provider: local | gemini | openai (default: local)
LLM_PROVIDER=local

# Local LLM (Ollama) — free, recommended for benchmarking
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL_NAME=llama3.2

# Ollama CPU optimization — reduce to speed up inference (at cost of output length)
# num_ctx: context window in tokens. 1024 fits all prompts safely (default Ollama: 2048).
OLLAMA_NUM_CTX=1024
# num_predict: max output tokens for correction/grading (examiner + arbiter)
OLLAMA_NUM_PREDICT=450
# num_predict for mock student answers (max 5 lines ≈ 180 tokens)
OLLAMA_NUM_PREDICT_ANSWER=180
# num_predict for batch question generation (5 questions + rubric ≈ 700 tokens)
OLLAMA_NUM_PREDICT_QUESTIONS=700

# Embeddings Provider: local | gemini | openai (default: local)
# "local" uses Ollama embeddings (free, nomic-embed-text recommended)
# NOTE: Changing provider requires recreating the ChromaDB index (delete data/vector_store/)
EMBEDDINGS_PROVIDER=local
LOCAL_EMBEDDINGS_MODEL=nomic-embed-text

# Cloud LLM: Google Gemini (uncomment to use)
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=your-gemini-api-key
# MODEL_NAME=gemini-2.0-flash

# Cloud LLM: OpenAI (uncomment to use)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# MODEL_NAME=gpt-4o-mini

# Temperature
TEMPERATURE=0

# Retry Configuration
MAX_RETRIES=3
INITIAL_RETRY_DELAY=2.0
MAX_RETRY_DELAY=30.0

# Divergence Threshold
DIVERGENCE_THRESHOLD=2.0

# Performance Tuning
API_CONCURRENCY=10
API_THROTTLE_SLEEP=0.3
BATCH_CHUNK_SIZE=5

# Analytics Thresholds (Phase 2)
GAP_THRESHOLD=6.0
STRENGTH_THRESHOLD=8.0
PLAGIARISM_THRESHOLD=0.90
DATA_RETENTION_DAYS=365

# LangSmith Configuration (optional)
# Get your key at: https://smith.langchain.com/
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_TRACING_ENABLED=true
LANGSMITH_PROJECT_NAME=ai-grading-system
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
